# .gitignore
# Files and folders that should NEVER be pushed to GitHub

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SECRETS — Most important!
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Next.js build output
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
.next/
out/

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Node.js dependencies
# (npm install regenerates this from package.json)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
node_modules/

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OS files
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
.DS_Store
Thumbs.db

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Debug logs
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Editor configs
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
.vscode/
.idea/
*.swp
*.swo
