# .env.local.example
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# NEVER commit .env.local to GitHub! It contains secret keys.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ──────────────────────────────────────
# OPENAI API KEY
# Get it from: https://platform.openai.com/api-keys
# Sign up → Billing → Add $5 (enough for hundreds of generations)
# Model used: gpt-4o-mini (cheapest, ~$0.0001 per generation)
# ──────────────────────────────────────
OPENAI_API_KEY=sk-proj-...your-key-here...

# ──────────────────────────────────────
# UNSPLASH API KEY (called "Access Key")
# Get it from: https://unsplash.com/developers
# Sign up → New Application → Copy "Access Key"
# Free tier: 50 requests/hour (plenty for a project)
# ──────────────────────────────────────
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# ──────────────────────────────────────
# MONGODB CONNECTION STRING
# Get it from: https://cloud.mongodb.com
# Steps:
#   1. Create free account
#   2. Create a cluster (free M0 tier)
#   3. Database Access → Add user (username + password)
#   4. Network Access → Allow 0.0.0.0/0 (all IPs, OK for dev)
#   5. Connect → Drivers → Copy connection string
#   6. Replace <password> with your actual password
#   7. Replace myFirstDatabase with: moodboard
# ──────────────────────────────────────
MONGODB_URI=mongodb+srv://yourusername:yourpassword@cluster0.xxxxx.mongodb.net/moodboard?retryWrites=true&w=majority

# ──────────────────────────────────────
# NEXTAUTH SECRET
# Used to encrypt JWT tokens (session cookies)
# Generate one with: openssl rand -base64 32
# Or use any long random string (min 32 chars)
# ──────────────────────────────────────
NEXTAUTH_SECRET=your-super-secret-random-string-at-least-32-chars-long

# ──────────────────────────────────────
# NEXTAUTH URL
# The URL where your app runs
# In development: http://localhost:3000
# In production: https://your-app-name.vercel.app
# ──────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000

# ──────────────────────────────────────
# GOOGLE OAUTH CREDENTIALS
# Get from: https://console.developers.google.com
# Steps:
#   1. Create project
#   2. Enable "Google+ API" (or "People API")
#   3. Credentials → Create OAuth 2.0 Client ID
#   4. Application type: Web application
#   5. Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
#   6. Copy Client ID and Client Secret
# ──────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
